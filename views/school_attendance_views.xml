<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="school_attendance_tree_view" model="ir.ui.view">
        <field name="name">school.attendance.tree</field>
        <field name="model">school.attendance</field>
        <field name="arch" type="xml">
            <list string="Attendances">
                <field name="name"/>
                <field name="session_id"/>
                <field name="academic_year_id"/>
                <field name="curriculum_id"/>
                <field name="course_id"/>
                <field name="teacher_id"/>
            </list>
        </field>
    </record>

    <record id="school_attendance_form_view" model="ir.ui.view">
        <field name="name">school.attendance.form</field>
        <field name="model">school.attendance</field>
        <field name="arch" type="xml">
            <form string="Attendance">
                <sheet>
                    <h1><field name="name"/></h1>

                        <group string="Class Information">
                            <field name="group_class_id"/>
                            <field name="session_id" domain="[('schedule_id.class_group_id','==',group_class_id)]"/>/>
                            <field name="curriculum_id"/>
                            <field name="academic_year_id"/>
                            <field name="course_id"/>
                        </group>
                        <group string="Teacher Information">
                            <field name="teacher_id"/>
                            <field name="room_id"/>
                        </group>
                    <notebook>
                        <page string="Students Attendance">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="student_id"/>
                                    <field name="gender"/>
                                    <field name="phone"/>
                                    <field name="email"/>
                                    <field name="state"/>
                                    <field name="reason"/>
                                </list>
                            </field>
                        </page>
                        <page string="Students">
                            <field name="student_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_school_setting_list" model="ir.ui.view">
        <field name="name">school.setting.list</field>
        <field name="model">school.setting</field>
        <field name="arch" type="xml">
            <list string="Theme Settings">
                <field name="name"/>
                <field name="text_color_primary"/>
                <field name="text_color_secondary"/>
                <field name="primary_color"/>
                <field name="secondary_color"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_school_setting_form" model="ir.ui.view">
        <field name="name">school.setting.form</field>
        <field name="model">school.setting</field>
        <field name="arch" type="xml">
            <form string="Theme Setting">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="text_color_primary" widget="color"/>
                            <field name="text_color_secondary" widget="color"/>
                            <field name="primary_color" widget="color"/>
                            <field name="secondary_color" widget="color"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <separator string="Theme Preview"/>
                    <div class="card shadow-sm mt-3">
                        <div class="card-header text-white"
                             style="background:#2d358e;">
                            School Management System
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <strong>Primary Text Color:</strong>
                                <field name="text_color_primary" readonly="1"/>
                            </div>
                            <div class="mb-3">
                                <strong>Secondary Text Color:</strong>
                                <field name="text_color_secondary" readonly="1"/>
                            </div>
                            <div class="mb-3">
                                <strong>Primary Color:</strong>
                                <field name="primary_color" readonly="1"/>
                            </div>
                            <div class="mb-3">
                                <strong>Secondary Color:</strong>
                                <field name="secondary_color" readonly="1"/>
                            </div>
                            <div class="alert alert-info" role="alert">
                                Change colors above and save.
                            </div>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_school_setting_kanban" model="ir.ui.view">
        <field name="name">school.setting.kanban</field>
        <field name="model">school.setting</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="text_color_primary"/>
                <field name="text_color_secondary"/>
                <field name="primary_color"/>
                <field name="secondary_color"/>
                <field name="active"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div t-attf-style="
                            background: linear-gradient(
                                135deg,
                                #{record.primary_color.raw_value},
                                #{record.secondary_color.raw_value}
                            );
                            color: #{record.text_color_primary.raw_value};
                            border-radius:16px;
                            padding:20px;
                            min-height:180px;
                            box-shadow:0 6px 20px rgba(0,0,0,0.15);">
                                <div class="d-flex justify-content-between align-items-center">
                                    <strong style="font-size:18px;">
                                        <field name="name"/>
                                    </strong>
                                    <span t-if="record.active.raw_value"
                                          class="badge bg-success rounded">
                                        Active
                                    </span>
                                    <span t-if="!record.active.raw_value"
                                          class="badge bg-danger rounded">
                                        Inactive
                                    </span>
                                </div>
                                <hr/>
                                <div class="mt-2">
                                    <strong>Primary</strong>
                                    <div t-attf-style="
                                    background:#{record.primary_color.raw_value};
                                    height:25px;
                                    border-radius:8px;
                                    margin-top:5px;"/>
                                </div>
                                <div class="mt-3">
                                    <strong>Secondary</strong>
                                    <div t-attf-style="
                                    background:#{record.secondary_color.raw_value};
                                    height:25px;
                                    border-radius:8px;
                                    margin-top:5px;"/>
                                </div>
                                <div class="mt-3">
                                    <small>
                                        Text Primary:
                                        <t t-esc="record.text_color_primary.value"/>
                                    </small>
                                    <br/>
                                    <small>
                                        Text Secondary:
                                        <t t-esc="record.text_color_secondary.value"/>
                                    </small>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_school_setting_search" model="ir.ui.view">
        <field name="name">school.setting.search</field>
        <field name="model">school.setting</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="active"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <filter string="Inactive" name="inactive" domain="[('active','=',False)]"/>
                <separator/>
            </search>
        </field>
    </record>

    <record id="action_school_setting" model="ir.actions.act_window">
        <field name="name">Theme Settings</field>
        <field name="res_model">school.setting</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

</odoo>
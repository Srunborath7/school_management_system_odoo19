<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_product_template_tree_school" model="ir.ui.view">
        <field name="name">product.template.tree.school</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="department_ids"/>
                <field name="school_type"/>
                <field name="academic_level_ids"/>
                <field name="school_note"/>
            </xpath>
        </field>
    </record>

    <record id="view_product_template_form_school" model="ir.ui.view">
        <field name="name">product.template.form.school</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='pos']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='purchase']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='inventory']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='invoicing']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="School Information">
                    <group>
                        <field name="department_ids"/>
                        <field name="school_type"/>
                        <field name="academic_level_ids"/>
                        <field name="school_note"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
    <record id="action_school_product_template" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_purchase_analysis_report_pivot" model="ir.ui.view">
        <field name="name">purchase.analysis.report.pivot</field>
        <field name="model">purchase.analysis.report</field>
        <field name="arch" type="xml">
            <pivot string="Purchase Analysis" disable_linking="True">
                <field name="partner_id" type="row"/>
                <field name="approval_state" type="col"/>
                <field name="date_order" interval="month" type="row"/>
                <field name="price_total" type="measure"/>
                <field name="qty_ordered" type="measure"/>
            </pivot>
        </field>
    </record>

   <record id="view_purchase_analysis_report_graph" model="ir.ui.view">
        <field name="name">purchase.analysis.report.graph</field>
        <field name="model">purchase.analysis.report</field>
        <field name="arch" type="xml">
            <graph string="Purchase Analysis" type="bar">
                <field name="partner_id" type="row"/>
                <field name="price_total" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_purchase_analysis_wizard" model="ir.actions.act_window">
        <field name="name">Purchase Analysis</field>
        <field name="res_model">purchase.analysis.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="action_purchase_analysis_report" model="ir.actions.act_window">
        <field name="name">Purchase Analysis</field>
        <field name="res_model">purchase.analysis.report</field>
        <field name="view_mode">pivot,graph</field>
        <!--        <field name="search_view_id" ref="view_purchase_analysis_report_search"/>-->
    </record>
</odoo>
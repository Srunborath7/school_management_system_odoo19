<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_school_course_list" model="ir.ui.view">
        <field name="name">school.course.list</field>
        <field name="model">school.course</field>
        <field name="arch" type="xml">
            <list string="Course">
                <field name="name"/>
                <field name="code"/>
                <field name="credits"/>
                <field name="creation_date"/>
                <field name="description"/>
            </list>
        </field>
    </record>
    <record id="view_school_course_form" model="ir.ui.view">
        <field name="name">school.course.form</field>
        <field name="model">school.course</field>
        <field name="arch" type="xml">
            <form string="Course">
                <sheet>
                    <h1><field name="code"/></h1>
                    <group>
                        <field name="name"/>
                        <field name="creation_date"/>
                        <field name="credits"/>
                        <field name="description"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_school_course_kanban" model="ir.ui.view">
        <field name="name">school.course.kanban</field>
        <field name="model">school.course</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="code"/>
                <field name="credits"/>
                <field name="creation_date"/>
                <field name="description"/>
                <field name="theme_primary"/>
                <field name="text_color_primary"/>
                <field name="theme_secondary"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click card border-0 shadow rounded-4 overflow-hidden">
                            <div class="card-header text-center text-white py-4"
                                 t-attf-style="background: linear-gradient(135deg,#{record.theme_primary.raw_value},#{record.theme_secondary.raw_value});
                                    color: #{record.text_color_primary.raw_value};">
                                <i class="fa fa-book fa-3x mb-2" title="Book"/>
                                <h4 class="mb-0 fw-bold text-white">
                                    <field name="name"/>
                                </h4>
                                <small class="opacity-75">
                                    Course Information
                                </small>
                            </div>
                            <div class="card-body">
                                <div class="mb-3 text-end text-white">
                                    <span class="badge rounded-pill bg-primary fs-6 px-3 py-2">
                                        <i class="fa fa-tag me-1" title="Tag"/>
                                        <field name="code"/>
                                    </span>
                                </div>
                                <div class="mb-2">
                                    <i class="fa fa-address-card text-primary me-2" title="Calendar"/>
                                    <strong>Credit: </strong>
                                    <field name="credits"/>
                                </div>
                                <div class="mb-2">
                                    <i class="fa fa-calendar text-primary me-2" title="Calendar"/>
                                    <strong>Created:</strong>
                                    <field name="creation_date"/>
                                </div>
                                <hr class="my-3"/>
                                <div class="mt-3">
                                    <i class="fa fa-quote-left text-primary me-2" title="quote"/>
                                    <strong>Description</strong>

                                    <blockquote class="blockquote mt-2 ps-3 border-start">
                                        <field name="description"/>
                                    </blockquote>
                                </div>
                            </div>
                            <div class="card-footer bg-light text-center">
                                <small class="text-muted">
                                    <i class="fa fa-graduation-cap me-1" title="Graduation"/>
                                    School Management System
                                </small>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="action_school_course" model="ir.actions.act_window">
        <field name="name">Course</field>
        <field name="res_model">school.course</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_school_curriculum_price_list" model="ir.ui.view">
        <field name="name">school.curriculum.price.list</field>
        <field name="model">school.curriculum.price</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="curriculum_id"/>
                <field name="price"/>
                <field name="discount"/>
                <field name="payment_term"/>
                <field name="amount"/>
                <field name="state"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="view_school_curriculum_price_form" model="ir.ui.view">
        <field name="name">school.curriculum.price.form</field>
        <field name="model">school.curriculum.price</field>
        <field name="arch" type="xml">
            <form string="School Curriculum">
                <header>
                    <button name="action_active" type="object" string="Activate" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_inactive" type="object" string="Inactive" invisible="state != 'active'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state != 'inactive'"/>
                    <button name="action_reset_draft" type="object" string="Reset Draft" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,inactive,cancel"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="curriculum_id"/>
                            <field name="price"/>
                            <field name="discount"/>
                            <field name="payment_term"/>
                            <field name="amount"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Note">
                            <field name="note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_school_curriculum_price_search" model="ir.ui.view">
        <field name="name">school.curriculum.price.search</field>
        <field name="model">school.curriculum.price</field>
        <field name="arch" type="xml">
            <search>
                <field name="curriculum_id"/>
                <field name="payment_term"/>
                <field name="state"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Active" name="active" domain="[('state','=','active')]"/>
                <filter string="Inactive" name="inactive" domain="[('state','=','inactive')]"/>
                <filter string="Cancel" name="closed" domain="[('state','=','cancel')]"/>
                <filter name="curriculum_id" string="Curriculum" context="{'group_by':'curriculum_id'}"/>
                <filter name="payment_term" string="Payment Term" context="{'group_by':'payment_term'}"/>
                <searchpanel>
                    <field name="state" string="Status" enable_counters="1"/>
                    <field name="curriculum_id" string="Curriculum" enable_counters="1"/>
                    <field name="payment_term" string="Payment Term" enable_counters="1"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="action_school_curriculum_price" model="ir.actions.act_window">
        <field name="name">Curriculum Price</field>
        <field name="res_model">school.curriculum.price</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_school_curriculum_price_search"/>
    </record>
</odoo>
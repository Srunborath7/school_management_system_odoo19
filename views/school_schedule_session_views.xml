<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="school_schedule_session_calendar_view" model="ir.ui.view">
        <field name="name">school.schedule.session.calendar</field>
        <field name="model">school.schedule.session</field>
        <field name="arch" type="xml">
            <calendar string="Class Sessions" date_start="start_datetime" date_stop="end_datetime" color="day" mode="week">
                <field name="course_id"/>
                <field name="teacher_id"/>
                <field name="room_id"/>
            </calendar>
        </field>
    </record>
    <record id="school_schedule_session_list_view" model="ir.ui.view">
        <field name="name">school.schedule.session.list</field>
        <field name="model">school.schedule.session</field>
        <field name="arch" type="xml">
            <list string="Class Sessions">
                <field name="schedule_id"/>
                <field name="curriculum_ids"/>
                <field name="class_group_id"/>
                <field name="course_id"/>
                <field name="teacher_id"/>
                <field name="room_id"/>
                <field name="start_datetime"/>
                <field name="end_datetime"/>
                <field name="start_time" widget="float_time"/>
                <field name="end_time" widget="float_time"/>
            </list>
        </field>
    </record>
    <record id="school_schedule_session_action" model="ir.actions.act_window">
        <field name="name">Class Sessions</field>
        <field name="res_model">school.schedule.session</field>
        <field name="view_mode">calendar,list,form</field>
    </record>
</odoo>
<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_school_acedemic_year_level_list" model="ir.ui.view">
        <field name="name">school.academic.year.level.list</field>
        <field name="model">school.academic.year.level</field>
        <field name="arch" type="xml">
            <list string="Academic Year Level">
                <field name="name"/>
                <field name="year"/>
                <field name="semester"/>
                <field name="degree"/>
                <field name="status"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_school_acedemic_year_level_form" model="ir.ui.view">
        <field name="name">school.academic.year.level.form</field>
        <field name="model">school.academic.year.level</field>
        <field name="arch" type="xml">
            <form string="Academic Year Level">
<!--                <header>-->
<!--                    <button name="action_active" type="object" string="Active" class="oe_highlight" invisible="status != 'draft'"/>-->
<!--                    <button name="action_completed" type="object" string="Complete" class="oe_highlight" invisible="status != 'active'"/>-->
<!--                    <button name="action_inactive" type="object" string="Inactive" invisible="status == 'inactive'"/>-->
<!--                    <button name="action_closed" type="object" string="Close" invisible="status != 'completed'"/>-->
<!--                    <button name="action_reset_draft" type="object" string="Reset" invisible="status == 'draft'"/>-->
<!--                    <field name="status" widget="statusbar" statusbar_visible="draft,active,completed,closed,inactive"/>-->
<!--                </header>-->
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="year"/>
                        <field name="semester"/>
                        <field name="degree"/>
                        <field name="status"/>
                        <field name="description"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="message_ids"/>
                </div>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_school_acedemic_year_level_kanban" model="ir.ui.view">
        <field name="name">school.academic.year.level.kanban</field>
        <field name="model">school.academic.year.level</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="year"/>
                <field name="semester"/>
                <field name="degree"/>+
                <field name="status"/>
                <field name="description"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click card border-0 shadow rounded-4 overflow-hidden">
                            <div class="card-header text-center text-white py-4"
                                 style="background: linear-gradient(135deg,#2d358e,#4f5bd5);border-radius: 24px 24px 0 0;box-shadow: 0 4px 12px rgba(0,0,0,.15);">
                                <i class="fa fa-university me-2 fa-3x" title="School"/>
                                <h4 class="md-0 fw-bold text-white mt-2">
                                    <field name="name"/>
                                </h4>
                                <small class="opacity-75">
                                    Academic Year Level Information
                                </small>
                            </div>
                            <div class="card-body">
                                <div class="mb-3 text-end text-white">
                                    <span class="badge rounded-pill bg-primary fs-6 px-3 py-2">
                                        <i class="fa fa-person-shelter me-1" title="Floor"/>
                                        <field name="status"/>
                                    </span>
                                </div>
                                <div class="mb-2">
                                    <i class="fa fa-calendar text-primary me-2" title="Capacity"/>
                                    <strong>Year Of Study: </strong>
                                    <field name="year"/>
                                </div>
                                <div class="mb-2">
                                    <i class="fa fa-book text-primary me-2" title="Capacity"/>
                                    <strong>Semester: </strong>
                                    <field name="semester"/>
                                </div>
                                <div class="mb-2">
                                    <i class="fa fa-graduation-cap text-primary me-2" title="Capacity"/>
                                    <strong>Degree: </strong>
                                    <field name="degree"/>
                                </div>
                                <hr class="my-3"/>
                                <div class="mt-3">
                                    <i class="fa fa-quote-left text-primary me-2" title="quote"/>
                                    <strong>Description</strong>

                                    <blockquote class="blockquote mt-2 ps-3 border-start">
                                        <field name="description"/>
                                    </blockquote>
                                </div>
                            </div>
                            <div class="card-footer bg-light text-center">
                                <small class="text-muted">
                                    <i class="fa fa-graduation-cap me-1" title="Graduation"/>
                                    School Management System
                                </small>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="view_school_acedemic_year_level_search" model="ir.ui.view">
        <field name="name">school.academic.year.level.search</field>
        <field name="model">school.academic.year.level</field>
        <field name="arch" type="xml">
            <search string="Search Academic Year Level">
                <field name="name"/>
                <field name="year"/>
                <field name="semester"/>
                <field name="status"/>
                <filter string="Draft" name="draft" domain="[('status','=','draft')]"/>
                <filter string="Active" name="active" domain="[('status','=','active')]"/>
                <filter string="Inactive" name="inactive" domain="[('status','=','inactive')]"/>
                <filter string="Closed" name="closed" domain="[('status','=','closed')]"/>
                <filter string="Completed" name="completed" domain="[('status','=','completed')]"/>
                <separator/>
                <filter string="Status" name="group_status" context="{'group_by':'status'}"/>
                <filter string="Year" name="group_start_date" context="{'group_by':'year'}"/>
                <filter string="Semester" name="group_end_date" context="{'group_by':'semester'}"/>
                <searchpanel>
                    <field name="status" string="Status" enable_counters="1"/>
                </searchpanel>
            </search>
        </field>
    </record>
    <record id="action_school_acedemic_year_level" model="ir.actions.act_window">
        <field name="name">Academic Year Level</field>
        <field name="res_model">school.academic.year.level</field>
        <field name="view_mode">list,form,kanban</field>
    </record>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View: add fields in a dedicated, labeled section -->
    <record id="view_partner_form_inherit" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.school</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="School Information" name="school_info">
                    <group>
                        <field name="customer_type"/>
                        <field name="customer_code"/>
                    </group>
                    <group>
                        <field name="credit_limit" widget="monetary"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_partner_list_inherit" model="ir.ui.view">
        <field name="name">res.partner.list.inherit.school</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list string="Partners" decoration-muted="not active">
                <field name="active" invisible="1"/>
                <field name="name"/>
                <field name="customer_type"/>
                <field name="customer_code"/>
                <field name="credit_limit" widget="monetary" sum="Total Credit Limit"/>
                <field name="email"/>
                <field name="phone"/>
            </list>
        </field>
    </record>


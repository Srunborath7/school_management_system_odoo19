<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="school_schedule_form_view" model="ir.ui.view">
        <field name="name">school.schedule.form</field>
        <field name="model">school.schedule</field>
        <field name="arch" type="xml">
            <form string="School Schedule">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="curriculum_id"/>
                        <field name="class_group_id"/>
                        <field name="state"/>
                    </group>
                    <notebook>
                        <page string="Weekly Timetable">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="day"/>
                                    <field name="course_id"/>
                                    <field name="teacher_id"/>
                                    <field name="room_id"/>
                                    <field name="start_time" widget="float_time"/>
                                    <field name="end_time" widget="float_time"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="school_schedule_list_view" model="ir.ui.view">
        <field name="name">school.schedule.list</field>
        <field name="model">school.schedule</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="class_group_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="school_schedule_action" model="ir.actions.act_window">
        <field name="name">Student Schedule</field>
        <field name="res_model">school.schedule</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
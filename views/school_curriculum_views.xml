<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_school_curriculum_list" model="ir.ui.view">
        <field name="name">school.curriculum.list</field>
        <field name="model">school.curriculum</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="major_id"/>
                <field name="academic_program_id"/>
                <field name="academic_year_id"/>
                <field name="academic_level_id"/>
                <field name="course_ids"/>
                <field name="total_credit"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_school_curriculum_form" model="ir.ui.view">
        <field name="name">school.curriculum.form</field>
        <field name="model">school.curriculum</field>
        <field name="arch" type="xml">
            <form string="School Curriculum">
                <header>
                    <button name="action_active" type="object" string="Activate" class="btn-primary" invisible="status != 'draft'"/>
                    <button name="action_inactive" type="object" string="Inactive" invisible="status != 'active'"/>
                    <button name="action_closed" type="object" string="Close" invisible="status != 'inactive'"/>
                    <button name="action_reset_draft" type="object" string="Reset Draft" invisible="status == 'draft'"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,active,inactive,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="major_id"/>
                            <field name="academic_program_id"/>
                            <field name="academic_year_id"/>
                            <field name="academic_level_id"/>
                        </group>
                        <group>
                            <field name="course_ids" widget="many2many_tags"/>
                            <field name="total_credit" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_school_curriculum_search" model="ir.ui.view">
        <field name="name">school.curriculum.search</field>
        <field name="model">school.curriculum</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="major_id"/>
                <field name="academic_program_id"/>
                <field name="academic_year_id"/>
                <field name="academic_level_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('status','=','draft')]"/>
                <filter string="Active" name="active" domain="[('status','=','active')]"/>
                <filter string="Inactive" name="inactive" domain="[('status','=','inactive')]"/>
                <filter string="Closed" name="closed" domain="[('status','=','closed')]"/>
                <filter name="group_major" string="Major" context="{'group_by':'major_id'}"/>
                <filter name="group_program" string="Program" context="{'group_by':'academic_program_id'}"/>
                <filter name="group_year" string="Academic Year" context="{'group_by':'academic_year_id'}"/>
                <filter name="group_level" string="Academic Level" context="{'group_by':'academic_level_id'}"/>
                <filter name="group_status" string="Status" context="{'group_by':'status'}"/>
                <searchpanel>
                    <field name="status" string="Status" enable_counters="1"/>
                    <field name="major_id" string="Major" enable_counters="1"/>
                    <field name="academic_program_id" string="Academic Program" enable_counters="1"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="action_school_curriculum" model="ir.actions.act_window">
        <field name="name">Curriculum</field>
        <field name="res_model">school.curriculum</field>
        <field name="view_mode">list,form</field>
<!--        <field name="search_view_id" ref="view_school_curriculum_search"/>-->
    </record>
</odoo>
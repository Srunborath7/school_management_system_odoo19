<!--                <button name="action_custom_reject"-->
<!--                        string="Reject"-->
<!--                        type="object"-->
<!--                        class="btn-secondary"-->
<!--                        invisible="approval_state != 'pending'"-->
<!--                        groups="purchase.group_purchase_manager"/>-->
<!--                <field name="approval_state" widget="statusbar"-->
<!--                       statusbar_visible="pending,approved,rejected"/>-->
<!--            </xpath>-->

            <!-- 2. Insert an approval info panel right after the vendor/partner field -->
<!--            <xpath expr="//field[@name='partner_id']" position="after">-->
<!--                <div class="alert alert-info" role="alert"-->
<!--                     invisible="approval_state != 'pending'">-->
<!--                    <strong>Pending Approval:</strong>-->
<!--                    This purchase order requires manager approval before confirmation.-->
<!--                </div>-->
<!--            </xpath>-->

            <!-- 3. Add a dedicated notebook tab with approval history/details -->
            <xpath expr="//notebook" position="inside">
                <page string="Approval" name="approval_info">
                    <group>
                        <group string="Status">
                            <field name="approval_state"/>
                            <field name="approved_by" readonly="1"/>
                            <field name="approved_date" readonly="1"/>
                        </group>
                        <group string="Notes">
                            <field name="approval_notes" placeholder="Reason for approval/rejection..."/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="action_purchase_order" model="ir.actions.act_window">
        <field name="name">Purchase Order</field>
        <field name="res_model">purchase.order</field>
        <field name="view_mode">list,form</field>
    </record>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Module Category -->
    <record id="module_category_school_management" model="ir.module.category">
        <field name="name">School Management</field>
        <field name="sequence">10</field>
    </record>

    <!-- Group Privilege -->
    <record id="school_management_privilege" model="res.groups.privilege">
        <field name="name">School Management</field>
        <field name="category_id" ref="school_management_system.module_category_school_management"/>
        <field name="sequence">10</field>
    </record>

    <!-- Admin -->
    <record id="group_school_management_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="privilege_id" ref="school_management_system.school_management_privilege"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Teacher -->
    <record id="group_school_management_teacher" model="res.groups">
        <field name="name">Teacher</field>
        <field name="privilege_id" ref="school_management_system.school_management_privilege"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Student -->
    <record id="group_school_management_student" model="res.groups">
        <field name="name">Student</field>
        <field name="privilege_id" ref="school_management_system.school_management_privilege"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

</odoo>
<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================
         Student: Only Active Records
    ============================= -->

    <record id="rule_student_active_registry" model="ir.rule">
        <field name="name">Student Active Registry</field>
        <field name="model_id" ref="model_school_student_registry"/>
        <field name="groups"
               eval="[(4, ref('school_management_system.group_school_management_student'))]"/>
        <field name="domain_force">
        [('create_uid', '=', user.id)]
    </field>
    </record>

    <!-- ============================
         Teacher: All Registry
    ============================= -->

    <record id="rule_teacher_registry" model="ir.rule">
        <field name="name">Teacher Registry</field>
        <field name="model_id" ref="model_school_student_registry"/>
        <field name="groups"
               eval="[(4, ref('school_management_system.group_school_management_teacher'))]"/>
        <field name="domain_force">
            [(1,'=',1)]
        </field>
    </record>

    <!-- ============================
         Admin: Full Access
    ============================= -->

    <record id="rule_admin_registry" model="ir.rule">
        <field name="name">Admin Registry</field>
        <field name="model_id" ref="model_school_student_registry"/>
        <field name="groups"
               eval="[(4, ref('school_management_system.group_school_management_admin'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
    </record>

</odoo>
<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_purchase_analysis_wizard_form" model="ir.ui.view">
        <field name="name">purchase.analysis.wizard.form</field>
        <field name="model">purchase.analysis.wizard</field>
        <field name="arch" type="xml">
            <form string="Purchase Analysis">

                <group>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="partner_id"/>
                </group>

                <footer>
                    <button
                        name="action_print_xlsx"
                        type="object"
                        string="Export Excel"
                        class="btn-primary"/>

                    <button
                        string="Cancel"
                        special="cancel"/>
                </footer>

            </form>
        </field>
    </record>

    <record id="action_purchase_analysis_wizard" model="ir.actions.act_window">
        <field name="name">Purchase Analysis</field>
        <field name="res_model">purchase.analysis.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_purchase_analysis_wizard_form"/>
        <field name="target">new</field>
    </record>

</odoo>
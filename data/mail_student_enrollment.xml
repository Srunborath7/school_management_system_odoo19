<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="email_template_student_enrollment" model="mail.template">
            <field name="name">Student Enrollment</field>

            <field name="model_id" ref="model_school_student_registry"/>

            <field name="subject">Welcome to Our School - {{ object.student_code }}</field>

            <field name="email_to">{{ object.email }}</field>

            <field name="email_from">{{ user.email or 'noreply@yourschool.com' }}</field>
        <field name="body_html" type="html">
            <div style="font-family:Arial,Helvetica,sans-serif;background:#f5f5f5;padding:30px;">

                <table width="650" align="center" cellpadding="0" cellspacing="0"
                       style="background:#ffffff;border-radius:8px;border:1px solid #dddddd;">

                    <tr>
                        <td style="background:#875A7B;color:#ffffff;padding:25px;text-align:center;">
                            <h2 style="margin:0;">Student Enrollment Successful</h2>
                        </td>
                    </tr>

                    <tr>
                        <td style="padding:30px;">

                            <p>Hello
                                <strong>
                                    <t t-out="object.name"/>
                                </strong>
                                ,
                            </p>

                            <p>
                                Congratulations! Your enrollment has been completed successfully.
                            </p>

                            <table width="100%" cellpadding="8"
                                   style="border-collapse:collapse;border:1px solid #e5e5e5;">

                                <tr style="background:#f8f8f8;">
                                    <td width="35%">
                                        <strong>Student Code</strong>
                                    </td>
                                    <td>
                                        <t t-out="object.student_code"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>Student Name</strong>
                                    </td>
                                    <td>
                                        <t t-out="object.name"/>
                                    </td>
                                </tr>

                                <tr style="background:#f8f8f8;">
                                    <td>
                                        <strong>Email</strong>
                                    </td>
                                    <td>
                                        <t t-out="object.email"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>Phone</strong>
                                    </td>
                                    <td>
                                        <t t-out="object.phone"/>
                                    </td>
                                </tr>

                                <tr style="background:#f8f8f8;">
                                    <td>
                                        <strong>Date of Birth</strong>
                                    </td>
                                    <td>
                                        <t t-out="object.DOB"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>Age</strong>
                                    </td>
                                    <td>
                                        <t t-out="object.calc_age"/>
                                        years
                                    </td>
                                </tr>

                                <tr style="background:#f8f8f8;">
                                    <td>
                                        <strong>Gender</strong>
                                    </td>
                                    <td>
                                        <t t-out="dict(object._fields['gender'].selection).get(object.gender)"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>Address</strong>
                                    </td>
                                    <td>
                                        <t t-out="object.address"/>
                                    </td>
                                </tr>

                                <tr style="background:#f8f8f8;">
                                    <td>
                                        <strong>Enrollment Date</strong>
                                    </td>
                                    <td>
                                        <t t-out="object.enrolled_date"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>Status</strong>
                                    </td>
                                    <td>
                                        <span style="background:#28a745;color:#ffffff;padding:5px 12px;border-radius:20px;">
                                            Enrolled
                                        </span>
                                    </td>
                                </tr>

                            </table>

                            <div style="margin-top:30px;text-align:center;">
                                <a t-att-href="object.get_base_url() + '/web#id=%s&amp;model=school.student.registry&amp;view_type=form' % object.id"
                                   style="background:#875A7B;color:#ffffff;padding:12px 25px;
                          text-decoration:none;border-radius:5px;font-weight:bold;">
                                    View Student Record
                                </a>
                            </div>

                            <p style="margin-top:30px;">
                                Thank you for joining our school. We wish you every success in your studies.
                            </p>

                        </td>
                    </tr>

                    <tr>
                        <td style="background:#f5f5f5;padding:20px;text-align:center;color:#888888;font-size:12px;">
                            School Management System
                            <br/>
                            This is an automated email. Please do not reply.
                        </td>
                    </tr>

                </table>

            </div>
        </field>
    </record>
</odoo>